# ── Polymarket CLOB API ──────────────────────────────────────────────
POLY_API_KEY=your_polymarket_api_key
POLY_API_SECRET=your_polymarket_api_secret
POLY_API_PASSPHRASE=your_polymarket_passphrase
POLY_PRIVATE_KEY=your_ethereum_private_key_hex
POLY_CHAIN_ID=137
# Static condition IDs (optional — leave empty when using auto-discovery)
POLY_BTC_CONDITION_IDS=

# ── Market Discovery ───────────────────────────────────────────────
# Auto-discover short-duration BTC Up/Down markets (5m, 15m, 1h, 4h)
# Uses predictive scheduling: polls aggressively around market boundaries,
# slowly in between. New markets are typically discovered within 2-5 seconds.
DISCOVERY_ENABLED=true
DISCOVERY_ASSETS=BTC
DISCOVERY_TIMEFRAMES=5m,15m
DISCOVERY_INTERVAL_S=15
# Burst mode: aggressive polling around predicted market creation times
DISCOVERY_BURST_INTERVAL_S=2.0
DISCOVERY_BURST_WINDOW_S=15
DISCOVERY_LEAD_TIME_S=5
DISCOVERY_MIN_SECONDS=60

# ── External Data Sources ────────────────────────────────────────────
CRYPTOCOMPARE_API_KEY=your_cryptocompare_key

# ── Strategy ─────────────────────────────────────────────────────────
# Probability-space edge thresholds:
#   edge = P(outcome) - market_mid_price
#   0.02 = require 2% probability advantage (conservative)
#   0.30 = max edge before assuming stale data (generous for near-expiry)
MIN_EDGE_THRESHOLD=0.02
MAX_EDGE_THRESHOLD=0.30
PREDICTION_HORIZON_S=900

# ── Risk ─────────────────────────────────────────────────────────────
MAX_POSITION_PCT=0.005
MAX_DAILY_LOSS_PCT=0.02
MAX_OPEN_POSITIONS=20

# ── Execution ────────────────────────────────────────────────────────
MAX_LATENCY_MS=100
MAX_ORDERS_PER_SECOND=50
HTTP_POOL_SIZE=20

# ── Machine Learning ──────────────────────────────────────────────────
# Enable ML prediction source (requires a trained model file).
ML_ENABLED=false
# Path to the trained model artifact (.pkl).
ML_MODEL_PATH=models/btc_5m_v2.pkl
# Rolling buffer size for the feature engine (seconds of price history).
ML_FEATURE_WINDOW=4000
# How often to emit ML predictions (seconds).
ML_PREDICTION_INTERVAL=0.25
# Minimum confidence to emit a prediction (0.0 = emit everything).
ML_MIN_CONFIDENCE=0.1
# Maximum predicted return magnitude (caps extreme predictions).
ML_MAX_PREDICTED_RETURN=0.01
# Prediction horizon in seconds (must match training labels).
ML_HORIZON_S=300

# ── Logging ──────────────────────────────────────────────────────────
LOG_LEVEL=INFO
